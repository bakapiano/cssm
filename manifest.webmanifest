{
  "id": "/ccsm/",
  "name": "CCSM",
  "short_name": "CCSM",
  "version": "0.17.6",
  "description": "Single pane over every live claude session on this machine.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone"
  ],
  "background_color": "#ffffff",
  "theme_color": "#ffffff",
  "icons": [
    {
      "src": "favicon.svg",
      "type": "image/svg+xml",
      "sizes": "any",
      "purpose": "any"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://bakapiano.github.io/ccsm/manifest.webmanifest"
    }
  ]
}